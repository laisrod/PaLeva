# ============================================
# PaLeva Frontend - Environment Variables
# ============================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env na mesma pasta
# 2. Preencha os valores conforme necessário
# 3. NUNCA commite o arquivo .env no Git (já está no .gitignore)
#
# Para desenvolvimento local:
#   cp frontend/.env.example frontend/.env
#
# IMPORTANTE: Variáveis no Vite devem começar com VITE_
# ============================================

# ============================================
# API Configuration
# ============================================
# URL base da API backend
# Desenvolvimento local: http://localhost:3000/api/v1
# Produção: https://paleva-backend.onrender.com/api/v1
VITE_API_URL=http://localhost:3000/api/v1

# ============================================
# WebSocket Configuration (Opcional)
# ============================================
# URL do WebSocket para Action Cable
# Desenvolvimento local: ws://localhost:3000
# Produção: wss://paleva-backend.onrender.com
# VITE_WS_URL=ws://localhost:3000

# ============================================
# Environment
# ============================================
# NODE_ENV=development
